.DS_Store

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Test and coverage artefacts
.pytest_cache/
.coverage
coverage.xml

# Build and install artefacts
*.egg-info/
dist/
build/
.venv/

# Rendered PDFs are build artefacts — except the example gallery,
# which is committed deliberately
*.pdf
!examples/*.pdf

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
